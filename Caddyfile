{$DOMAIN} {
	encode zstd gzip

	tls {$ACME_EMAIL}

	# Redirect bare /api to /api/ so handle_path below matches
	redir /api /api/ permanent

	# Backend: strip the /api prefix before proxying to Express
	handle_path /api/* {
		reverse_proxy backend-prod:8001
	}

	# Frontend: everything else goes to Next.js
	handle {
		reverse_proxy frontend-prod:3000
	}
}
